<%- include('../partials/header') %>

<div style="max-width:480px; margin:0 auto;">
  <div class="card">
    <h2>📝 Daftar Akun Baru</h2>

    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <ul class="errors">
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
      </ul>
    <% } %>

    <form method="POST" action="/register">
      <div class="form-group">
        <label>Nama Lengkap *</label>
        <input type="text" name="name" class="form-control" required placeholder="Nama kamu">
      </div>
      <div class="form-group">
        <label>Email *</label>
        <input type="email" name="email" class="form-control" required placeholder="email@contoh.com">
      </div>
      <div class="form-group">
        <label>No. HP</label>
        <input type="text" name="phone" class="form-control" placeholder="08xx-xxxx-xxxx">
      </div>
      <div class="form-group">
        <label>Password * (min. 6 karakter)</label>
        <input type="password" name="password" class="form-control" required placeholder="••••••••">
      </div>
      <div class="form-group">
        <label>Daftar Sebagai *</label>
        <select name="role" class="form-control" required>
          <option value="buyer">🛒 Buyer — Saya ingin membeli</option>
          <option value="seller">🛍️ Seller — Saya ingin menjual</option>
        </select>
      </div>
      <button type="submit" class="btn btn-success" style="width:100%; padding:12px; font-size:15px;">Daftar Sekarang</button>
    </form>

    <p style="text-align:center; margin-top:16px; font-size:14px; color:#666;">
      Sudah punya akun? <a href="/login">Login di sini</a>
    </p>
  </div>
</div>

<%- include('../partials/footer') %>