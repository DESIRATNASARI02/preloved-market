<%- include('../partials/header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
  <h1>📦 Item Saya</h1>
  <a href="/items/add" class="btn btn-success">+ Tambah Item</a>
</div>

<% if (typeof message !== 'undefined' && message) { %>
  <div class="alert alert-success"><%= message %></div>
<% } %>

<% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
  <ul class="errors">
    <% errors.forEach(e => { %><li><%= e %></li><% }) %>
  </ul>
<% } %>

<% if (items.length === 0) { %>
  <div class="card" style="text-align:center; padding:40px; color:#999;">
    <p style="font-size:40px;">📦</p>
    <p>Kamu belum punya item. Mulai jual sekarang!</p>
    <a href="/items/add" class="btn btn-success" style="margin-top:12px;">+ Tambah Item</a>
  </div>
<% } else { %>
  <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px;">
    <% items.forEach(item => { %>
      <div class="card" style="padding:0; overflow:hidden;">
        <% if (item.imageUrl) { %>
          <img src="<%= item.imageUrl %>" alt="<%= item.name %>" style="width:100%; height:160px; object-fit:cover;">
        <% } else { %>
          <div style="height:100px; background:linear-gradient(135deg,#667eea,#764ba2); display:flex; align-items:center; justify-content:center; font-size:40px;">📦</div>
        <% } %>
        <div style="padding:16px;">
          <h3 style="font-size:15px; margin-bottom:6px;"><%= item.name %></h3>
          <p style="font-size:18px; font-weight:bold; color:#e74c3c; margin-bottom:8px;"><%= formatRupiah(item.price) %></p>

          <!-- Tags -->
          <% if (item.Tags && item.Tags.length > 0) { %>
            <div style="margin-bottom:8px;">
              <% item.Tags.forEach(tag => { %><span class="badge">#<%= tag.name %></span><% }) %>
            </div>
          <% } %>

          <p style="font-size:12px; color:#888; margin-bottom:12px;">
            Kondisi: <%= item.condition === 'new' ? 'Baru' : item.condition === 'like_new' ? 'Seperti Baru' : item.condition === 'good' ? 'Bagus' : 'Cukup' %>
            &nbsp;|&nbsp; Stok: <%= item.stock %>
          </p>

          <div style="display:flex; gap:8px;">
            <a href="/items/<%= item.id %>/edit" class="btn btn-warning" style="flex:1; text-align:center;">✏️ Edit</a>
            <form method="POST" action="/items/<%= item.id %>/delete" style="flex:1;" onsubmit="return confirm('Yakin hapus item ini?')">
              <button type="submit" class="btn btn-danger" style="width:100%;">🗑️ Hapus</button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
