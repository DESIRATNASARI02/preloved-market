<%- include('../partials/header') %>

<div style="max-width:800px; margin:0 auto;">
  <a href="/" style="color:#3498db; font-size:14px;">← Kembali ke Beranda</a>

  <% if (typeof message !== 'undefined' && message) { %>
    <div class="alert alert-success" style="margin-top:16px;"><%= message %></div>
  <% } %>

  <div class="card" style="margin-top:16px; padding:0; overflow:hidden;">
    <% if (item.imageUrl) { %>
      <img src="<%= item.imageUrl %>" alt="<%= item.name %>" style="width:100%; max-height:400px; object-fit:cover;">
    <% } else { %>
      <div style="height:200px; background:linear-gradient(135deg,#667eea,#764ba2); display:flex; align-items:center; justify-content:center; font-size:64px;">📦</div>
    <% } %>

    <div style="padding:24px;">
      <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px;">
        <div>
          <h1 style="font-size:24px; margin-bottom:8px;"><%= item.name %></h1>
          <p style="font-size:28px; font-weight:bold; color:#e74c3c;"><%= formatRupiah(item.price) %></p>
        </div>
        <div style="text-align:right;">
          <span style="background:#eafaf1; color:#27ae60; padding:6px 12px; border-radius:20px; font-size:13px;">
            <%= item.condition === 'new' ? 'Baru' : item.condition === 'like_new' ? 'Seperti Baru' : item.condition === 'good' ? 'Bagus' : 'Cukup' %>
          </span>
          <p style="color:#888; font-size:13px; margin-top:8px;">Stok: <%= item.stock %></p>
        </div>
      </div>

      <% if (item.Tags && item.Tags.length > 0) { %>
        <div style="margin:16px 0;">
          <% item.Tags.forEach(tag => { %><span class="badge">#<%= tag.name %></span><% }) %>
        </div>
      <% } %>

      <div style="border-top:1px solid #f0f0f0; padding-top:16px; margin-top:16px;">
        <h3 style="font-size:16px; margin-bottom:8px;">Deskripsi</h3>
        <p style="color:#555; line-height:1.6;"><%= item.description || 'Tidak ada deskripsi.' %></p>
      </div>

      <!-- seller info - eager loading User + UserProfile -->
      <div style="border-top:1px solid #f0f0f0; padding-top:16px; margin-top:16px; background:#f9f9f9; border-radius:8px; padding:16px;">
        <h3 style="font-size:15px; margin-bottom:8px;">Info Penjual</h3>
        <p style="font-size:14px;"><strong>👤 <%= item.User && item.User.UserProfile ? item.User.UserProfile.name : item.User.email %></strong></p>
        <% if (item.User && item.User.UserProfile && item.User.UserProfile.phone) { %>
          <p style="font-size:13px; color:#666; margin-top:4px;">📱 <%= item.User.UserProfile.phone %></p>
        <% } %>
        <% if (item.User && item.User.UserProfile && item.User.UserProfile.address) { %>
          <p style="font-size:13px; color:#666; margin-top:4px;">📍 <%= item.User.UserProfile.address %></p>
        <% } %>
        <p style="font-size:12px; color:#bbb; margin-top:8px;">📅 Diposting <%= formatDate(item.createdAt) %></p>
      </div>

      <% if (!currentUser) { %>
        <div style="margin-top:20px; text-align:center;">
          <p style="color:#888; margin-bottom:12px;">Login untuk menghubungi penjual</p>
          <a href="/login" class="btn btn-primary" style="padding:12px 32px; font-size:15px;">Login Sekarang</a>
        </div>
      <% } else if (currentUser.role === 'buyer') { %>
        <div style="margin-top:20px;">
          <a href="https://wa.me/<%= item.User.UserProfile.phone %>?text=Halo%2C%20saya%20tertarik%20dengan%20<%= encodeURIComponent(item.name) %>%20seharga%20<%= encodeURIComponent(formatRupiah(item.price)) %>" 
            target="_blank" 
            class="btn btn-success" 
            style="width:100%; text-align:center; padding:14px; font-size:15px;">
            💬 Hubungi via WhatsApp
          </a>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>